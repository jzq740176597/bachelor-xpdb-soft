// Collision_Shapes.compute
//
// Supported shape types:
//   SHAPE_SPHERE   (0)  analytic — point vs sphere
//   SHAPE_OBB      (1)  analytic — point vs oriented box
//   SHAPE_CAPSULE  (2)  analytic — point vs capsule  (spherical end-caps)
//   SHAPE_CONVEX   (4)  face-plane inside test — convex MeshCollider
//
// Collider kinds:
//   COL_STATIC    (0) — no velocity, no impulse feedback
//   COL_KINEMATIC (1) — surface velocity inherited by particle
//   COL_DYNAMIC   (2) — mass-weighted split + Newton-3rd impulse → Rigidbody
//
// ShapeDescriptor (64 bytes, 4×float4, 16-byte aligned):
//   word0  shapeType | colType | dynSlot | rbInvMass
//   word1  centre.xyz | param0
//   word2  axis.xyz   | param1
//   word3  axis2.xyz  | param2
//
//   Sphere:   centre, param0=radius
//   OBB:      centre, axis=worldLocalX, axis2=worldLocalY,
//             param0=halfX, param2=halfZ
//             param1=halfY         (interior mode, thick box)
//             param1=-halfY        (CCD mode, thin/flat box: segment vs face)
//   Capsule:  centre, axis=segAxis, param0=radius, param1=halfHeight
//   Convex:   centre=meshOrigin (unused by GPU),
//             param0=asuint(faceOffset), param1=asuint(faceCount),
//             axis=worldAABB_centre, axis2=worldAABB_halfExtents,
//             param2 unused
//
// Contact skin:
//   A single _ContactSkin uniform replaces all per-shape skin constants.
//   Set from CPU each frame as: clamp(softBodyMaxExtent * 0.25, 0.005, 0.10)
//   This makes the skin automatically scale with the soft body size so that
//   a 1cm body and a 1m body both get appropriate detection margins.
//
// _MeshFacePlanes : float4[] — world-space face planes for ALL convex meshes
//   packed flat; plane = float4(normal.xyz, d)
//   inside test: dot(normal, worldPoint) + d < 0
//
// ImpulseBytes layout per dynamic slot (32 bytes):
//   +0   impulse.xyz   (float×3, atomic CAS)
//   +12  hitCount      (uint,    InterlockedAdd)
//   +16  contactSum.xyz (float×3, atomic CAS — averaged on CPU)
//   +28  _pad

#pragma kernel ClearImpulseAccum
#pragma kernel DetectShapes
#pragma kernel SolveCollisions
#pragma kernel WriteCollisionState
#pragma kernel ClearCollisionState
#pragma kernel HardProjectParticles

#pragma target 5.0

#define EPSILON          1e-6
#define MAX_CONSTRAINTS  10000
#define GROUP_SIZE       32
#define IMPULSE_STRIDE   32u

#define COL_STATIC       0u
#define COL_KINEMATIC    1u
#define COL_DYNAMIC      2u

#define SHAPE_SPHERE     0u
#define SHAPE_OBB        1u
#define SHAPE_CAPSULE    2u
#define SHAPE_CONVEX     4u

// ── Structs ───────────────────────────────────────────────────────────────────

struct ShapeDescriptor
{
	uint   shapeType; uint colType; uint dynSlot; float rbInvMass;
	float3 centre;    float param0;
	float3 axis;      float param1;
	float3 axis2;     float param2;
};

struct Particle     { float3 position; float _p0; float3 velocity; float invMass; };
struct PbdPositions { float3 predict;  float _p0; float3 delta;    float _p1;    };

struct ColConstraint
{
	float3 contactPt; // plane contacts: point on surface; sphere CCD: sphere end-centre
	uint   pIdx;
	float3 normal;
	float  surfVelN;
	uint   colType;
	uint   dynSlot;
	float  rbInvMass;
	float  sphereRadius; // > 0 → sphere CCD mode (re-evaluate at solve time); 0 → plane mode
};

// ── Uniforms ──────────────────────────────────────────────────────────────────

float _ColDeltaTime;
uint  _ShapeCount;
uint  _ParticleCount;
uint  _DynSlotCount;

// Unified contact skin width — set from CPU each frame.
// Scales with soft-body size: clamp(maxExtent * 0.25, 0.005, 0.10).
// Applied to ALL shape types (sphere, capsule, OBB) for consistent behaviour.
float _ContactSkin;

// Effective radius per soft-body particle — fills inter-particle surface gaps.
// Collision detection expands by this so small colliders cannot slip between particles.
float _ParticleRadius;

// Weight multiplier for collision delta contribution.
// Higher = collision correction dominates over elastic Stretch/Volume corrections.
// Set from CPU as SubSteps (e.g. 20) so collision always wins.
float _CollisionDeltaWeight;

// ── Buffers ───────────────────────────────────────────────────────────────────

StructuredBuffer<ShapeDescriptor> _Shapes;
StructuredBuffer<float3>          _ShapeVelocities;
StructuredBuffer<float4>          _MeshFacePlanes;

RWStructuredBuffer<Particle>      _Particles;
RWStructuredBuffer<PbdPositions>  _Positions;
RWStructuredBuffer<uint>          _ColSize;
RWStructuredBuffer<ColConstraint> _ColConstraints;
RWByteAddressBuffer               _ImpulseBytes;

// Per-particle collision state: float4(normal.xyz, depth).
// depth < 0 = penetrating; >= 1e9 = no collision.
// Written by WriteCollisionState, read by ClampDelta in SoftBodySim.compute.
RWStructuredBuffer<float4>        _CollisionState;

// Delta accumulation buffer — same ComputeBuffer as _Delta in SoftBodySim.compute.
// SolveCollisions writes collision corrections here so Postsolve velocity
// reflects the outward push. Bound from C# as the body's delta buffer.
RWByteAddressBuffer               _DeltaRaw;

// ── Atomic float CAS ─────────────────────────────────────────────────────────

void AtomicAddF(uint addr, float v)
{
	uint prev = _ImpulseBytes.Load(addr);
	uint next;
	[allow_uav_condition]
	do
	{
		next = asuint(asfloat(prev) + v);
		uint orig;
		_ImpulseBytes.InterlockedCompareExchange(addr, prev, next, orig);
		if (orig == prev)
		{
			break;
		}
		prev = orig;
	} while (true);
}

// Atomically add float to _DeltaRaw (same CAS pattern, different buffer).
void AtomicAddDeltaF(uint byteOffset, float value)
{
	uint prev = _DeltaRaw.Load(byteOffset);
	uint next;
	[allow_uav_condition]
	do
	{
		next = asuint(asfloat(prev) + value);
		uint orig;
		_DeltaRaw.InterlockedCompareExchange(byteOffset, prev, next, orig);
		if (orig == prev)
			break;
		prev = orig;
	} while (true);
}

void AtomicAddToDelta(uint pIdx, float3 v)
{
	uint base = pIdx * 12u;  // float3 = 12 bytes
	AtomicAddDeltaF(base + 0u, v.x);
	AtomicAddDeltaF(base + 4u, v.y);
	AtomicAddDeltaF(base + 8u, v.z);
}

// ── Kernel: ClearImpulseAccum ─────────────────────────────────────────────────

[numthreads(GROUP_SIZE, 1, 1)]
void ClearImpulseAccum(uint3 id : SV_DispatchThreadID)
{
	if (id.x >= _DynSlotCount) return;
	uint b = id.x * IMPULSE_STRIDE;
	_ImpulseBytes.Store(b +  0, 0u); _ImpulseBytes.Store(b +  4, 0u);
	_ImpulseBytes.Store(b +  8, 0u); _ImpulseBytes.Store(b + 12, 0u);
	_ImpulseBytes.Store(b + 16, 0u); _ImpulseBytes.Store(b + 20, 0u);
	_ImpulseBytes.Store(b + 24, 0u); _ImpulseBytes.Store(b + 28, 0u);
}

// ── Analytic tests ────────────────────────────────────────────────────────────
//
// TestSphere uses swept CCD (segment-vs-moving-sphere):
//   Particle travels from _Particles[pi].position → predict in one substep.
//   Sphere centre travels from s.axis (start) → s.centre (end) in the same substep.
//   We solve for the earliest t ∈ [0,1] where |particleLerp(t) - sphereLerp(t)| = r.
//   This is a quadratic in t; the smallest positive real root is the contact time.
//   Contact point and normal are computed at that t.
//   Fallback: if no swept contact, test static position with skin (catches slow cases).
//
// Other shapes (OBB, capsule, convex) use static skin detection:
//   detect radius = real radius + _ContactSkin
//   contact point = real surface
//   SolveCollisions applies positional correction even in the skin zone.

bool TestSphere(ShapeDescriptor s, float3 pEnd, float3 pStart, out float3 cp, out float3 n)
{
	cp = float3(0, 0, 0);
	n  = float3(0, 1, 0);
	float r = s.param0;

	// Relative motion: particle relative to sphere over the substep.
	// rel(t) = (pStart + t*(pEnd-pStart)) - (sStart + t*(sEnd-sStart))
	//        = rel0 + t * relV
	float3 sStart = s.axis;    // sphere centre at substep START (encoded by CPU)
	float3 sEnd   = s.centre;  // sphere centre at substep END
	float3 rel0   = pStart - sStart;
	float3 relV   = (pEnd - pStart) - (sEnd - sStart);

	// Quadratic: |rel0 + t*relV|² = r²
	// a*t² + b*t + c = 0
	float a = dot(relV, relV);
	float b = 2.0 * dot(rel0, relV);
	float c = dot(rel0, rel0) - r * r;

	bool foundSwept = false;
	float tHit = 1.0;

	// c < 0 means particle is ALREADY inside the sphere at t=0.
	// In this case the quadratic has one negative root (entry, already past)
	// and one positive root (exit). We want t=0 — the particle is inside right now.
	// Flag it so SolveCollisions gets a constraint at t=0 and the re-evaluation
	// from sphere centre will find pen < 0 and correct it immediately.
	if (c < 0.0)
	{
		// Already penetrating at substep start. Return contact at current position.
		float3 d   = pStart - sStart;
		float  len = length(d);
		n  = len > EPSILON ? d / len : float3(0, 1, 0);
		cp = sStart;   // sphere centre stored — SolveCollisions uses sphereRadius mode
		return true;
	}

	if (a > EPSILON)
	{
		float disc = b * b - 4.0 * a * c;
		if (disc >= 0.0)
		{
			float sqrtDisc = sqrt(disc);
			float t0 = (-b - sqrtDisc) / (2.0 * a);   // entry (smaller root)
			float t1 = (-b + sqrtDisc) / (2.0 * a);   // exit  (larger root)

			// Pick t0 (entry). If t0 < 0 the entry already passed but t1 > 0
			// means we are currently inside — handled above via c < 0 check.
			if (t0 >= 0.0 && t0 <= 1.0)
			{
				tHit       = t0;
				foundSwept = true;
			}
		}
	}

	if (foundSwept)
	{
		// Compute contact position and normal at tHit
		float3 particleAtT = pStart + tHit * (pEnd - pStart);
		float3 sphereAtT   = sStart + tHit * (sEnd   - sStart);
		float3 d           = particleAtT - sphereAtT;
		float  dist        = length(d);
		n  = dist > EPSILON ? d / dist : float3(0, 1, 0);
		cp = sphereAtT + n * r;
		return true;
	}

	// Fallback: static skin test for slow/grazing contacts missed by sweep.
	float3 dEnd = pEnd - sEnd;
	float  d2   = dot(dEnd, dEnd);
	// Expand detection by _ParticleRadius: each particle is effectively
	// a sphere of this radius, covering inter-particle surface gaps.
	float  rSkin = r + _ContactSkin + _ParticleRadius;
	if (d2 >= rSkin * rSkin)
	{
		return false;
	}
	float dist = sqrt(d2);
	n  = dist > EPSILON ? dEnd / dist : float3(0, 1, 0);
	cp = sEnd + n * r;
	return true;
}

// ── OBB collision — speculative signed-distance (Unity/PhysX model) ────────────
//
// WHY NOT SWEEP (CCD segment-vs-face):
//   A sweep test computes where (prev→predict) crosses a face. But collision
//   runs AFTER Stretch+Volume+Postsolve, so `prev` (= position at substep start)
//   and `p` (= predict after all elastic corrections) are no longer a clean
//   segment. Elastic constraints may have moved `p` in arbitrary directions.
//   Using a stale `prev` for the segment origin causes missed or incorrect contacts.
//
// SPECULATIVE SIGNED-DISTANCE (correct approach):
//   For each axis project the predicted position onto the face plane.
//   If the signed distance is inside the box (negative penetration): contact.
//   Choose the shallowest penetrating face as the contact normal.
//   This is what Unity's speculative CCD and PhysX's contact generation do:
//   they look at WHERE the point IS, not how it got there.
//
// _ContactSkin (skin width, replaces old OBB_CONTACT_OFFSET):
//   param1 stores hy:
//     param1 >= 0 → interior mode, hy = param1 (thick box, normal 3D test)
//     param1 <  0 → speculative mode, hy = -param1 (thin/flat box)
//   In speculative mode _ContactSkin is added to hy so that a zero-thickness
//   floor (hy≈0) gets an effective half-extent of (hy + _ContactSkin).
//   Any particle within _ContactSkin of the surface generates a contact.
bool TestOBB(ShapeDescriptor s, float3 p, out float3 cp, out float3 n)
{
	cp = 0;
	n  = float3(0, 1, 0);
	float3 d  = p - s.centre;
	float3 ax = s.axis, ay = s.axis2, az = cross(ax, ay);
	float  lx = dot(d, ax), ly = dot(d, ay), lz = dot(d, az);

	bool speculative = (asuint(s.param1) & 0x80000000u) != 0u;

	if (speculative)
	{
		float hx   = s.param0;
		float hz   = s.param2;
		float skin = _ContactSkin;
		if (abs(lx) >= hx) return false;
		if (abs(lz) >= hz) return false;
		if (ly >= skin)    return false;   // above skin → no contact

		float raw_hy = abs(s.param1);
		cp = s.centre + ay * raw_hy + ax * lx + az * lz;
		n  = ay;
		return true;
	}

	// ── Interior (thick box) ──────────────────────────────────────────────────
	float hx = s.param0, hy = s.param1, hz = s.param2;
	if (abs(lx) >= hx || abs(ly) >= hy || abs(lz) >= hz) return false;
	float px = hx - abs(lx), py = hy - abs(ly), pz = hz - abs(lz);
	if (px <= py && px <= pz)
	{
		n  = ax * sign(lx);
		cp = s.centre + ax * (hx * sign(lx)) + ay * ly + az * lz;
	}
	else if (py <= pz)
	{
		n  = ay * sign(ly);
		cp = s.centre + ax * lx + ay * (hy * sign(ly)) + az * lz;
	}
	else
	{
		n  = az * sign(lz);
		cp = s.centre + ax * lx + ay * ly + az * (hz * sign(lz));
	}
	return true;
}

bool TestCapsule(ShapeDescriptor s, float3 p, out float3 cp, out float3 n)
{
	cp = 0;
	n  = float3(0, 1, 0);
	float3 a  = s.centre - s.axis * s.param1;
	float3 b  = s.centre + s.axis * s.param1;
	float3 ab = b - a;
	float  r  = s.param0;
	float  t  = saturate(dot(p - a, ab) / max(dot(ab, ab), EPSILON));
	float3 cl = a + ab * t;
	float3 dv = p - cl;
	float  d2 = dot(dv, dv);
	// Expand detection by particle radius: each soft particle is a sphere of
	// radius _ParticleRadius. Small colliders smaller than inter-particle spacing
	// are caught because they enter the particle's effective sphere before the gap.
	float  rDet = r + _ContactSkin + _ParticleRadius;
	if (d2 >= rDet * rDet)
	{
		return false;
	}
	float dist = sqrt(d2);
	n  = dist > EPSILON ? dv / dist : float3(0, 1, 0);
	cp = cl + n * r;   // contact on real surface
	return true;
}

// Convex mesh: point must be on the negative side of ALL face planes.
// Contact = shallowest-penetrating face (smallest penetration depth).
// Note: convex uses strict interior test (no skin expansion needed —
// the face-plane test is already conservative for particle-sized objects).
bool TestConvex(ShapeDescriptor s, float3 p, out float3 cp, out float3 n)
{
	cp = 0;
	n  = float3(0, 1, 0);

	// AABB bounds reject
	float3 bDelta = abs(p - s.axis) - s.axis2;
	if (bDelta.x > 0.0 || bDelta.y > 0.0 || bDelta.z > 0.0) return false;

	uint faceOffset = asuint(s.param0);
	uint faceCount  = asuint(s.param1);
	if (faceCount == 0u) return false;

	float minPen   = 1e38;
	int   bestFace = -1;

	for (uint fi = 0u; fi < faceCount; fi++)
	{
		float4 pl   = _MeshFacePlanes[faceOffset + fi];
		float  dist = dot(pl.xyz, p) + pl.w;
		if (dist >= 0.0) return false;
		float pen = -dist;
		if (pen < minPen)
		{
			minPen   = pen;
			bestFace = (int)fi;
		}
	}

	if (bestFace < 0) return false;
	float4 best = _MeshFacePlanes[faceOffset + (uint)bestFace];
	n  = best.xyz;
	cp = p + best.xyz * minPen;
	return true;
}

// ── Kernel: DetectShapes ──────────────────────────────────────────────────────
// One thread per (shape × particle). Index = si * _ParticleCount + pi.
//
// For sphere: passes both particle.position (substep start) and predict (substep end)
// so TestSphere can do a true swept CCD test.
// For other shapes: passes predict only (static skin detection).

[numthreads(GROUP_SIZE, 1, 1)]
void DetectShapes(uint3 id : SV_DispatchThreadID)
{
	if (id.x >= _ShapeCount * _ParticleCount) return;
	uint si = id.x / _ParticleCount;
	uint pi = id.x % _ParticleCount;

	ShapeDescriptor s    = _Shapes[si];
	float3 pEnd          = _Positions[pi].predict;
	float3 pStart        = _Particles[pi].position;  // set by Presolve each substep

	float3 cp, n;
	bool   hit;
	if (s.shapeType == SHAPE_SPHERE)
	{
		hit = TestSphere(s, pEnd, pStart, cp, n);
	}
	else if (s.shapeType == SHAPE_OBB)
	{
		hit = TestOBB(s, pEnd, cp, n);
	}
	else if (s.shapeType == SHAPE_CAPSULE)
	{
		hit = TestCapsule(s, pEnd, cp, n);
	}
	else
	{
		hit = TestConvex(s, pEnd, cp, n);
	}

	if (!hit) return;

	uint slot;
	InterlockedAdd(_ColSize[0], 1u, slot);
	if (slot >= MAX_CONSTRAINTS) return;

	float3 sv   = _ShapeVelocities[si];
	ColConstraint c;
	// For sphere CCD contacts: store sphere end-centre in contactPt and
	// radius in sphereRadius so SolveCollisions can re-evaluate penetration
	// using actual sphere geometry (not a stale tangent plane).
	// For all other contacts: store surface point in contactPt, sphereRadius=0.
	if (s.shapeType == SHAPE_SPHERE)
	{
		c.contactPt    = s.centre;    // sphere end-centre
		c.sphereRadius = s.param0;    // sphere radius
	}
	else
	{
		c.contactPt    = cp;
		c.sphereRadius = 0.0;
	}
	c.pIdx       = pi;
	c.normal     = n;
	c.surfVelN   = dot(sv, n);
	c.colType    = s.colType;
	c.dynSlot    = s.dynSlot;
	c.rbInvMass  = s.rbInvMass;
	_ColConstraints[slot] = c;
}

// ── Kernel: SolveCollisions ───────────────────────────────────────────────────
//
// Sphere mode (sphereRadius > 0):
//   Re-evaluate penetration as actual distance from sphere centre.
//   This is exact even after Stretch/Volume moved predict.
//
// Plane mode (sphereRadius == 0):
//   Signed distance from the stored surface plane.
//
// On penetration (pen < 0):
//   1. Push predict to surface (positional correction).
//   2. Also update particle.position to match — this prevents the velocity
//      that Postsolve wrote (which pointed inward due to elastic forces) from
//      re-integrating the particle back inside next substep. Without this,
//      the stable penetrating equilibrium forms: elastic forces > collision
//      correction force, and the particle settles inside the sphere.
//   3. Kill relative inward velocity component.
//
// On skin zone (pen >= 0): kill inward velocity only, no position change.

[numthreads(GROUP_SIZE, 1, 1)]
void SolveCollisions(uint3 id : SV_DispatchThreadID)
{
	uint i = id.x;
	if (i >= _ColSize[0] || i >= MAX_CONSTRAINTS) return;

	ColConstraint c   = _ColConstraints[i];
	float3 pos        = _Positions[c.pIdx].predict;
	float3 nrm        = c.normal;

	float pInv = _Particles[c.pIdx].invMass;
	float cInv = c.rbInvMass;
	float wTot = pInv + cInv;

	// Re-evaluate penetration from current predict.
	float pen;
	if (c.sphereRadius > 0.0)
	{
		float3 toParticle = pos - c.contactPt;
		float  dist       = length(toParticle);
		nrm = dist > EPSILON ? toParticle / dist : c.normal;
		pen = dist - c.sphereRadius;
	}
	else
	{
		float planeDist = dot(c.contactPt, nrm);
		pen = dot(pos, nrm) - planeDist;
	}

	if (pen < 0.0)
	{
		float3 corr = -nrm * pen;
		float3 newPredict;
		if (wTot > EPSILON)
			newPredict = pos + corr * (pInv / wTot);
		else
			newPredict = pos + corr;

		_Positions[c.pIdx].predict = newPredict;
		_Particles[c.pIdx].position = newPredict;

		// Note: no delta injection here. HardProjectParticles runs last and
		// provides the hard positional guarantee. Delta injection caused
		// explosions when correction distance * weight was large.
	}

	// Kill relative inward velocity — applies in both skin zone and penetration.
	float3 pVel  = _Particles[c.pIdx].velocity;
	float  vRelN = dot(pVel, nrm) - c.surfVelN;
	if (vRelN < 0.0)
		_Particles[c.pIdx].velocity -= nrm * vRelN;

	// Dynamic: Newton-3rd impulse (only on full penetration).
	if (pen < 0.0 && c.colType == COL_DYNAMIC && wTot > EPSILON)
	{
		float3 corr  = -nrm * pen;
		float3 rbImp = -corr * (cInv / wTot) / _ColDeltaTime;
		uint   b     = c.dynSlot * IMPULSE_STRIDE;
		float3 contactForImpulse = (c.sphereRadius > 0.0)
			? (c.contactPt + nrm * c.sphereRadius)
			: c.contactPt;
		AtomicAddF(b +  0, rbImp.x);
		AtomicAddF(b +  4, rbImp.y);
		AtomicAddF(b +  8, rbImp.z);
		AtomicAddF(b + 16, contactForImpulse.x);
		AtomicAddF(b + 20, contactForImpulse.y);
		AtomicAddF(b + 24, contactForImpulse.z);
		uint dummy;
		_ImpulseBytes.InterlockedAdd(b + 12, 1u, dummy);
	}
}
// ── Kernel: ClearCollisionState ──────────────────────────────────────────────
// Resets per-particle collision state to "no collision" each substep.
// Must run before Presolve so ClampDelta sees fresh data.

[numthreads(GROUP_SIZE, 1, 1)]
void ClearCollisionState(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= _ParticleCount) return;
    _CollisionState[id.x] = float4(0.0, 1.0, 0.0, 1e9);
}

// ── Kernel: WriteCollisionState ───────────────────────────────────────────────
// Marks each particle that had a collision contact this substep so ClampDelta
// can suppress inward elastic deltas.
//
// KEY: evaluate depth from raw sphere geometry, NOT from the corrected predict.
// SolveCollisions already pushed predict to the surface (pen ≈ 0), so
// evaluating pen from predict returns >= 0 and nothing would get written.
// Instead use the stored sphere centre + radius directly.
//
// Write state for particles within _ContactSkin of the surface (pen < _ContactSkin).
// A just-corrected particle has pen ≈ 0 — still within skin — so it gets marked
// and ClampDelta blocks Stretch/Volume from pulling it back inside.

[numthreads(GROUP_SIZE, 1, 1)]
void WriteCollisionState(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= _ColSize[0] || i >= MAX_CONSTRAINTS) return;

    ColConstraint c = _ColConstraints[i];
    float3 pos = _Positions[c.pIdx].predict;
    float3 nrm;
    float  pen;

    if (c.sphereRadius > 0.0)
    {
        float3 toParticle = pos - c.contactPt;   // contactPt = sphere end-centre
        float  dist       = length(toParticle);
        nrm = dist > EPSILON ? toParticle / dist : c.normal;
        // Use rExclude = sphereRadius + _ParticleRadius so particles in the
        // particle-radius zone are also marked for elastic exclusion.
        pen = dist - (c.sphereRadius + _ParticleRadius);
    }
    else
    {
        nrm = c.normal;
        float planeDist = dot(c.contactPt, nrm);
        pen = dot(pos, nrm) - planeDist;
    }

    // Write for any particle at or near the surface (pen < _ContactSkin).
    // This covers: just-corrected (pen ≈ 0), still-penetrating (pen < 0),
    // and approaching particles in the skin zone.
    if (pen >= _ContactSkin) return;

    _CollisionState[c.pIdx] = float4(nrm.x, nrm.y, nrm.z, pen);
}
// ── Kernel: HardProjectParticles ─────────────────────────────────────────────
// Runs as the ABSOLUTE LAST step of the substep, after Postsolve and all
// collision passes. Directly checks every particle against every shape using
// the analytic formula — no constraint buffer, no delta, no indirection.
//
// For spheres: pen = length(predict - centre) - radius
// If pen < 0: project predict to surface, kill inward velocity.
//
// This is a hard positional guarantee: nothing runs after this, so elastic
// constraints cannot undo it. No matter how stiff Stretch/Volume are, the
// particle ends the substep outside the collider.
//
// Thread = one particle. Inner loop over all shapes (typically 1-3 shapes).
// Cost = O(particles × shapes) with no atomics — each thread owns its particle.

[numthreads(GROUP_SIZE, 1, 1)]
void HardProjectParticles(uint3 id : SV_DispatchThreadID)
{
    uint pi = id.x;
    if (pi >= _ParticleCount) return;

    float3 pos = _Positions[pi].predict;
    float3 vel = _Particles[pi].velocity;

    for (uint si = 0u; si < _ShapeCount; si++)
    {
        ShapeDescriptor s = _Shapes[si];
        float3 surfVel    = _ShapeVelocities[si];

        if (s.shapeType == SHAPE_SPHERE)
        {
            float3 toP      = pos - s.centre;
            float  dist     = length(toP);
            float  r        = s.param0;
            // Exclusion zone = grip radius + particle radius.
            // Particle centre must stay outside this combined radius.
            float  rExclude = r + _ParticleRadius;
            float  pen      = dist - rExclude;
            if (pen >= 0.0) continue;

            // Project particle CENTRE to rExclude from grip centre.
            // (rExclude = grip_r + particle_r, so particle sphere just touches grip sphere)
            // Only correct if actually inside rExclude — never pull inward from outside.
            float3 nrm = dist > EPSILON ? toP / dist : float3(0, 1, 0);
            pos = s.centre + nrm * rExclude;

            // Kill inward relative velocity.
            float vRelN = dot(vel - surfVel, nrm);
            if (vRelN < 0.0)
                vel -= nrm * vRelN;
        }
        else if (s.shapeType == SHAPE_CAPSULE)
        {
            float3 a  = s.centre - s.axis * s.param1;
            float3 b  = s.centre + s.axis * s.param1;
            float3 ab = b - a;
            float  r  = s.param0;
            float  t  = saturate(dot(pos - a, ab) / max(dot(ab, ab), EPSILON));
            float3 cl = a + ab * t;
            float3 dv = pos - cl;
            float  dist = length(dv);
            float  pen  = dist - r;
            if (pen >= 0.0) continue;

            float3 nrm = dist > EPSILON ? dv / dist : float3(0, 1, 0);
            pos = cl + nrm * r;
            float vRelN = dot(vel - surfVel, nrm);
            if (vRelN < 0.0)
                vel -= nrm * vRelN;
        }
        else if (s.shapeType == SHAPE_OBB)
        {
            // Reuse TestOBB logic inline for the speculative floor case.
            float3 d  = pos - s.centre;
            float3 ax = s.axis, ay = s.axis2, az = cross(ax, ay);
            float  lx = dot(d, ax), ly = dot(d, ay), lz = dot(d, az);
            bool   speculative = (asuint(s.param1) & 0x80000000u) != 0u;
            if (speculative)
            {
                float hx = s.param0, hz = s.param2;
                if (abs(lx) >= hx || abs(lz) >= hz || ly >= 0.0) continue;
                float3 nrm = ay;
                pos = s.centre + ay * abs(s.param1) + ax * lx + az * lz;
                float vRelN = dot(vel - surfVel, nrm);
                if (vRelN < 0.0)
                    vel -= nrm * vRelN;
            }
            else
            {
                float hx = s.param0, hy = s.param1, hz = s.param2;
                if (abs(lx) >= hx || abs(ly) >= hy || abs(lz) >= hz) continue;
                float px = hx - abs(lx), py = hy - abs(ly), pz = hz - abs(lz);
                float3 nrm;
                float3 cp;
                if (px <= py && px <= pz)
                {
                    nrm = ax * sign(lx);
                    cp  = s.centre + ax * (hx * sign(lx)) + ay * ly + az * lz;
                }
                else if (py <= pz)
                {
                    nrm = ay * sign(ly);
                    cp  = s.centre + ax * lx + ay * (hy * sign(ly)) + az * lz;
                }
                else
                {
                    nrm = az * sign(lz);
                    cp  = s.centre + ax * lx + ay * ly + az * (hz * sign(lz));
                }
                pos = cp;
                float vRelN = dot(vel - surfVel, nrm);
                if (vRelN < 0.0)
                    vel -= nrm * vRelN;
            }
        }
        else if (s.shapeType == SHAPE_CONVEX)
        {
            // AABB bounds reject (same as TestConvex).
            float3 bDelta = abs(pos - s.axis) - s.axis2;
            if (bDelta.x > 0.0 || bDelta.y > 0.0 || bDelta.z > 0.0) continue;

            uint faceOffset = asuint(s.param0);
            uint faceCount  = asuint(s.param1);
            if (faceCount == 0u) continue;

            // Find shallowest-penetrating face.
            float minPen   = 1e38;
            int   bestFace = -1;
            for (uint fi = 0u; fi < faceCount; fi++)
            {
                float4 pl   = _MeshFacePlanes[faceOffset + fi];
                float  dist = dot(pl.xyz, pos) + pl.w;
                if (dist >= 0.0) { bestFace = -1; break; } // outside this plane = not inside
                float pen = -dist;
                if (pen < minPen) { minPen = pen; bestFace = (int)fi; }
            }
            if (bestFace < 0) continue;

            float4 best = _MeshFacePlanes[faceOffset + (uint)bestFace];
            float3 nrm  = best.xyz;
            pos = pos + nrm * minPen;   // push to surface along shallowest face

            float vRelN = dot(vel - surfVel, nrm);
            if (vRelN < 0.0)
                vel -= nrm * vRelN;
        }
    }

    _Positions[pi].predict    = pos;
    _Particles[pi].velocity   = vel;
    // Keep position in sync so next Presolve starts from outside.
    _Particles[pi].position   = pos;
}
